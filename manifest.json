{
  "manifest_version": 3,
  "name": "Shopify Data Extractor Pro",
  "version": "1.0",
  "description": "Premium Shopify store data extraction tool for collections and products",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "1028248991787-iqn8c4h1giu0m3l5s90oh4dc9tul9488.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "*://*/*",
    "https://www.google.com/s2/favicons*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopify Data Extractor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [{
    "resources": ["results.html", "results.js", "results.css", "db.js", "history.html", "history.js", "history.css"],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}